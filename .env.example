# =============================================================================
# ARCHITECTURE: Frontend (Vercel) + Base de données (Railway PostgreSQL)
# =============================================================================
#
# ÉTAPES DE CONFIGURATION:
#
# 1. RAILWAY (Base de données uniquement)
#    → railway.app → New Project → Add PostgreSQL
#    → Connect tab → copier "Public Network URL" (commence par postgresql://)
#    → Cette URL est utilisée PARTOUT (Vercel + dev local)
#
# 2. VERCEL (App Next.js complète)
#    → vercel.com → Import Git Repository → mkstone68-creator/istic
#    → Settings → Environment Variables → ajouter toutes les variables ci-dessous
#    → Settings → Domains → ajouter isticvote.online
#
# 3. FAPSHI (Paiement Mobile Money Cameroun)
#    → fapshi.com → Paramètres → API → copier les clés
#    → Webhooks → URL: https://isticvote.online/api/webhook/fapshi
#
# 4. CLOUDINARY (Photos candidats)
#    → cloudinary.com → Dashboard → Account Details
#
# =============================================================================

# ── Base de données ─────────────────────────────────────────────────────────
# Railway → PostgreSQL service → Connect → "Public Network" (pas "Private Network")
DATABASE_URL="postgresql://postgres:PASSWORD@HOST.railway.app:PORT/railway"

# ── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://isticvote.online"

# ── Mode paiement ────────────────────────────────────────────────────────────
# "mock" pour tests locaux | "production" en ligne
PAYMENT_MODE="production"

# ── Fapshi (Mobile Money) ────────────────────────────────────────────────────
FAPSHI_MODE=live
FAPSHI_API_USER="d35d9fc8-7194-43d9-a223-1362fa145e0f"
FAPSHI_API_KEY="FAK_b85b6ebed7da36f9fa504d5dd363eb07"
NEXT_PUBLIC_APP_URL=https://isticvote.online
VOTE_AMOUNT=100

# ── Cloudinary (Photos) ──────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="votre_cloud_name"
CLOUDINARY_API_KEY="votre_api_key"
CLOUDINARY_API_SECRET="votre_api_secret"

# ── Admin (/admin) ───────────────────────────────────────────────────────────
ADMIN_PASSWORD="mot_de_passe_admin_fort"
# Générer avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET="chaine_aleatoire_64_caracteres"
